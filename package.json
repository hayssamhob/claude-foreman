    "smee-client": "^5.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "allowScripts": {
    "better-sqlite3@12.10.0": true,
    "esbuild@0.28.1": true
