# --- GitHub App credentials (from your app's settings page) ---
APP_ID=
PRIVATE_KEY_PATH=./private-key.pem
WEBHOOK_SECRET=

# Local development: a https://smee.io channel URL that forwards webhooks to localhost
WEBHOOK_PROXY_URL=

# --- Agent fleet ---
# Comma-separated junior agent names. Each gets an `agent:<name>` routing label.
# "claude" is the in-process junior (headless Claude Code) — see JUNIOR_* below.
AGENTS=antigravity,windsurf,claude

# Minutes a junior holds a task after claiming before the lease expires
LEASE_TTL_MINUTES=120

# Max concurrent tasks per agent (some agents juggle parallel work badly).
# Unlisted agents default to 2.
AGENT_LIMITS=windsurf:1,antigravity:3,claude:1

# Max manager revision rounds before a task is reassigned to another agent
MAX_REVISION_ROUNDS=2

# --- Manager (Claude Fable via headless Claude Code) ---
# Command used to invoke the manager model. Must accept a prompt on stdin and
# print a single JSON object to stdout. Default expects the Claude Code CLI.
MANAGER_CMD=claude -p --output-format json --tools "" --max-turns 1
# Set to 1 to skip spawning the CLI and mark manager jobs as needs-human (useful before the CLI is installed)
MANAGER_DISABLED=0

# --- Auto-merge ---
# 1 (default): approved PRs merge themselves once CI is green, every review
# conversation is resolved, and the task issue does not carry the `hold` label.
# 0: approved PRs wait for you to click "Accept & merge" on the dashboard.
AUTO_MERGE=1

# --- In-process junior (headless Claude Code as a coding agent) ---
JUNIOR_ENABLED=1
JUNIOR_AGENT=claude
JUNIOR_CMD=claude -p --output-format json --dangerously-skip-permissions
JUNIOR_TIMEOUT_MINUTES=30
WORKSPACES_DIR=./data/workspaces

# --- Push notifications (ntfy.sh) ---
# Pick a hard-to-guess topic and subscribe to it in the ntfy mobile/desktop
# app (https://ntfy.sh). Empty = notifications off.
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# --- Storage ---
DB_PATH=./data/agent-manager.db
